extends ./layout.pug

block content
    h1 HI DEAR #{$userName}

    h2 HERE ARE ALL YOUR POSTS YES
    .userPosts
        if count($cats) > 0
            each $cat in ($cats)
                .card(id="catCard-{$cat['id']}")
                    h4= $cat['name']
                    h5= $cat['breed']
                    |
                    .imgBox(style="height:20vw;width:auto;aspect-ratio:1/1;")
                        img(src=$cat['img'] style="width:100%;height:100%;object-fit:cover;")
                    |
                    button(onclick="deleteCar({$cat['id']})") DELETE
        else
            p you have neow cattos posted

block feet
    .updateProfileForum
        form(action="../updateProfile", method="patch" enctype="multipart/form-data" class="updateProfileForum" id="UPF")
            label(for="password") password?
            |
            input(id="password", name="password", type="password", placeholder="password?")
            |
            label(for="uEmail") update email?
            |
            input(id="uEmail" type="text", name="uEmail", placeholder="update email?")
            |
            label(for="uName") change user?
            |
            input(id="uName" type="text" name="uName" placeholder="update username?" value=$userName)
            |
            label(for="submitButtonPro") all done?
            |
            button(id="submitButtonPro" type="button" onclick="submitProfileChanges()" value="update profile") UPDATE PROFILE

    .DeleteProfile
        button(onclick="deleteProfile()") DELETE ACCOUNT

